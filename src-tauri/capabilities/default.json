{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "WareMaster default capability set: bundled-resource read access, scoped vault read/write, and folder picker dialogs.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:path:default",
    "dialog:default",
    "dialog:allow-open",
    "updater:default",
    "process:default",
    "fs:default",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$DOCUMENT/WareMaster/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$RESOURCE/**" }
      ]
    },
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-exists",
    "fs:allow-read-dir"
  ]
}
