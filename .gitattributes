# Normalize line endings on commit
* text=auto eol=lf

# Binary files (never normalize)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.woff binary
*.woff2 binary

# Lock files: keep platform-native
package-lock.json text eol=lf
pnpm-lock.yaml text eol=lf
Cargo.lock text eol=lf
